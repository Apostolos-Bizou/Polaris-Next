# ═══════════════════════════════════════════════════════════
# POLARIS - Environment Configuration
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════

# ─── NextAuth.js ──────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# ─── Google Apps Script (existing backend) ────────────────
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/AKfycbye9XIpC0VLyBLftcN3ew5nw7BvbKd19-_JCR-xfKWEtjbvWYJqdvOSjfoaruI7ixp6/exec

# ─── Azure AD / Entra ID (optional - enable when ready) ──
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# ─── Azure Cosmos DB (Phase 6 - not needed yet) ──────────
# COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
# COSMOS_KEY=your-primary-key-here
# COSMOS_DATABASE=polaris

# ─── App Settings ─────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Polaris
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
